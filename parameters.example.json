{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "japaneast"
    },
    "resourceGroupPrefix": {
      "value": "rg-dify"
    },
    "pgsqlUser": {
      "value": "adminuser"
    },
    "pgsqlPassword": {
      "value": "YOUR_SECURE_PASSWORD_HERE"
    },
    "isProvidedCert": {
      "value": false
    },
    "acaCertPassword": {
      "value": "YOUR_CERT_PASSWORD_HERE"
    },
    "acaAppMinCount": {
      "value": 1
    },
    "isAcaEnabled": {
      "value": true
    },
    "useEntraIdForAoai": {
      "value": true
    },
    "aoaiAccountBase": {
      "value": "aoaidify"
    },
    "aoaiSkuName": {
      "value": "S0"
    },
    "aoaiPublicNetworkAccess": {
      "value": "Enabled"
    },
    "aoaiAllowedIpRanges": {
      "value": [
        "10.0.0.0/8"
      ]
    },
    "aoaiApiVersion": {
      "value": "2024-10-21"
    },
    "aoaiChatDeploymentName": {
      "value": "chat"
    },
    "aoaiChatModelName": {
      "value": "gpt-4o-mini"
    },
    "aoaiChatModelVersion": {
      "value": "2024-07-18"
    },
    "aoaiEmbeddingDeploymentName": {
      "value": "embedding"
    },
    "aoaiEmbeddingModelName": {
      "value": "text-embedding-3-large"
    },
    "aoaiEmbeddingModelVersion": {
      "value": "1"
    },
    "difyUamiName": {
      "value": "dify-uami"
    }
  }
}
